#pragma once

/* WiFi credentials */
#define WIFI_SSID       "YourSSID"
#define WIFI_PASSWORD   "YourPassword"

/* MQTT broker — use LAN IP (not localhost) to reach host from ESP32 */
#define MQTT_BROKER     "192.168.1.X"
#define MQTT_PORT       1883
#define MQTT_USER       "fovet-device"
#define MQTT_PASSWORD   "your-mqtt-password"

/* Device identifier — must match mqttClientId in the Vigie DB */
#define DEVICE_ID       "esp32-cam-001"
