#ifndef FOVET_CONFIG_H
#define FOVET_CONFIG_H

/* WiFi credentials */
#define WIFI_SSID      "your_wifi_ssid"
#define WIFI_PASSWORD  "your_wifi_password"

/* MQTT broker — Mosquitto local (port 1883) ou VPS Scaleway */
#define MQTT_BROKER    "192.168.1.x"   /* IP de la machine qui exécute Mosquitto */
#define MQTT_PORT      1883
#define MQTT_USER      "fovet-device"
#define MQTT_PASSWORD  "change_me"

/* Identité du device — doit correspondre au mqttClientId enregistré dans Vigie */
#define DEVICE_ID      "esp32cam_001"

#endif /* FOVET_CONFIG_H */
