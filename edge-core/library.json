{
  "name": "ardent-pulse",
  "version": "0.1.0",
  "description": "Ardent SDK — Pulse: embedded anomaly detection (C99, zero malloc)",
  "license": "LGPL-3.0",
  "keywords": ["anomaly-detection", "embedded", "zscore", "ewma", "drift", "esp32"],
  "frameworks": ["arduino", "espidf"],
  "platforms": ["espressif32", "native"],
  "build": {
    "includeDir": "include",
    "srcDir": "src",
    "srcFilter": [
      "+<zscore.c>",
      "+<drift.c>",
      "+<mad.c>",
      "+<biosignal_hal.c>",
      "+<mpu6050_hal.c>",
      "+<max30102_hal.c>",
      "+<dht22_hal.c>",
      "+<drivers/mpu6050.c>",
      "+<profiles/pti_profile.c>",
      "+<profiles/fatigue_profile.c>",
      "+<profiles/temp_profile.c>",
      "+<platform/platform_esp32.cpp>"
    ]
  }
}
