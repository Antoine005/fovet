// Ardent Watch — Prisma Schema
// PostgreSQL + TimescaleDB (timescaledb extension activated in production)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------------------------------
// Device — a Ardent Pulse node (ESP32-CAM or any MCU)
// -------------------------------------------------------------------------
model Device {
  id          String    @id @default(cuid())
  name        String
  description String?
  location    String?
  mqttClientId String   @unique  // e.g. "esp32-cam-001"
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  readings    Reading[]
  alerts      Alert[]

  @@map("devices")
}

// -------------------------------------------------------------------------
// Reading — a single sensor sample from a device
// Time-series table — will be converted to TimescaleDB hypertable in prod
// -------------------------------------------------------------------------
model Reading {
  id         BigInt    @id @default(autoincrement())
  deviceId   String
  timestamp  DateTime  @default(now())
  value      Float                       // Raw sensor value (primary — temp °C, BPM, accel g, z-score)
  value2     Float?                      // Secondary value — humidity % (TEMP module)
  mean       Float                       // Running mean at time of reading (0 for canonical payloads)
  stddev     Float                       // Running stddev at time of reading (0 for canonical payloads)
  zScore     Float                       // |value - mean| / stddev (0 for canonical payloads)
  isAnomaly  Boolean   @default(false)
  // Module that produced this reading: "IMU" | "HR" | "TEMP" | null (legacy/unknown)
  sensorType String?
  // Firmware that published this reading: "person_detection" | "fire_detection" | "zscore_demo" | "smoke_test" | null
  firmware   String?
  // Forge model identifier — matches pipeline name in manifest (e.g. "demo-zscore-sine")
  modelId    String?
  // Value unit for Watch chart Y-axis: "z_score" | "g" | "score" | "bpm" | "C" | "r_mean" | "mad_score"
  unit       String?
  // Expected value range from manifest — Watch uses these to auto-scale the chart
  valueMin   Float?
  valueMax   Float?
  // Human-readable label: "normal" | "anomaly" | "person" | "no_person" | "fire"
  label      String?

  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp(sort: Desc)])
  @@index([deviceId, sensorType, timestamp(sort: Desc)])
  @@index([deviceId, modelId, timestamp(sort: Desc)])
  @@map("readings")
}

// -------------------------------------------------------------------------
// Forge — Model registry
// -------------------------------------------------------------------------
model CastModel {
  id         String   @id @default(cuid())
  name       String   // "Ardent-Fatigue"
  type       String   // "FAT" | "PTI" | "STR"
  version    String   // "v2.3.1"
  status     String   // "PROD" | "TRAIN" | "ARCH"
  sizeKb     Float?
  latencyMs  Float?
  accuracy   Float?
  driftScore Float?
  driftLevel String?  // "ok" | "med" | "crit"
  driftNote  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  jobs       CastJob[]
  deploys    CastDeploy[]

  @@map("forge_models")
}

// -------------------------------------------------------------------------
// Forge — Training jobs
// -------------------------------------------------------------------------
model CastJob {
  id              String    @id @default(cuid())
  jobRef          String    @unique  // "#JB-0041"
  modelId         String?
  status          String    // "RUNNING" | "DONE" | "FAILED" | "CANCELLED"
  progress        Int       @default(0)
  currentEpoch    Int       @default(0)
  totalEpochs     Int       @default(50)
  eta             String?
  datasetSessions Int?
  logs            String?   @db.Text
  trainLoss       Float?
  valLoss         Float?
  valAccuracy     Float?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())

  model           CastModel? @relation(fields: [modelId], references: [id])

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("forge_jobs")
}

// -------------------------------------------------------------------------
// Forge — OTA deployments
// -------------------------------------------------------------------------
model CastDeploy {
  id         String   @id @default(cuid())
  deployRef  String   @unique  // "#DEP-0038"
  modelId    String
  deviceIds  String   // JSON array of device ids
  status     String   // "PENDING" | "SUCCESS" | "FAILED" | "PARTIAL"
  results    String?  // JSON: { deviceId: "ok" | "fail" }
  deployedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  model      CastModel @relation(fields: [modelId], references: [id])

  @@index([deployedAt(sort: Desc)])
  @@map("forge_deploys")
}

// -------------------------------------------------------------------------
// Forge — Audit log (deploy, retrain, promote, reject)
// -------------------------------------------------------------------------
model CastAudit {
  id        String   @id @default(cuid())
  actor     String   // "a.porte"
  action    String   // "JOB_START" | "JOB_CANCEL" | "DATASET_VALIDATED" | "DEPLOY" | "PROMOTE" | "REJECT"
  label     String?  // human-readable description
  modelRef  String?  // model name + version for display
  jobRef    String?
  deployRef String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("forge_audit")
}

// -------------------------------------------------------------------------
// Alert — an anomaly event persisted for notification and history
// -------------------------------------------------------------------------
model Alert {
  id          String    @id @default(cuid())
  deviceId    String
  timestamp   DateTime  @default(now())
  value       Float
  zScore      Float
  threshold   Float
  // PTI profile alert type: "FALL" | "MOTIONLESS" | "SOS" — null for non-PTI alerts
  ptiType     String?
  // Module that raised this alert: "PTI" | "FATIGUE" | "THERMAL" — null for legacy z-score alerts
  alertModule String?
  // Severity level from Pulse profile: "WARN" | "DANGER" | "COLD" | "CRITICAL"
  alertLevel  String?
  acknowledged Boolean  @default(false)
  acknowledgedAt DateTime?

  device      Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp(sort: Desc)])
  @@index([ptiType, timestamp(sort: Desc)])
  @@index([alertModule, timestamp(sort: Desc)])
  @@map("alerts")
}
