// Fovet Vigie — Prisma Schema
// PostgreSQL + TimescaleDB (timescaledb extension activated in production)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------------------------------
// Device — a Fovet Sentinelle node (ESP32-CAM or any MCU)
// -------------------------------------------------------------------------
model Device {
  id          String    @id @default(cuid())
  name        String
  description String?
  location    String?
  mqttClientId String   @unique  // e.g. "esp32-cam-001"
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  readings    Reading[]
  alerts      Alert[]

  @@map("devices")
}

// -------------------------------------------------------------------------
// Reading — a single sensor sample from a device
// Time-series table — will be converted to TimescaleDB hypertable in prod
// -------------------------------------------------------------------------
model Reading {
  id         BigInt    @id @default(autoincrement())
  deviceId   String
  timestamp  DateTime  @default(now())
  value      Float                       // Raw sensor value (primary — temp °C, BPM, accel g)
  value2     Float?                      // Secondary value — humidity % (TEMP module)
  mean       Float                       // Running mean at time of reading
  stddev     Float                       // Running stddev at time of reading
  zScore     Float                       // |value - mean| / stddev
  isAnomaly  Boolean   @default(false)
  // Module that produced this reading: "IMU" | "HR" | "TEMP" | null (legacy/unknown)
  sensorType String?

  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp(sort: Desc)])
  @@index([deviceId, sensorType, timestamp(sort: Desc)])
  @@map("readings")
}

// -------------------------------------------------------------------------
// Alert — an anomaly event persisted for notification and history
// -------------------------------------------------------------------------
model Alert {
  id          String    @id @default(cuid())
  deviceId    String
  timestamp   DateTime  @default(now())
  value       Float
  zScore      Float
  threshold   Float
  // PTI profile alert type: "FALL" | "MOTIONLESS" | "SOS" — null for non-PTI alerts
  ptiType     String?
  // Module that raised this alert: "PTI" | "FATIGUE" | "THERMAL" — null for legacy z-score alerts
  alertModule String?
  // Severity level from Sentinelle profile: "WARN" | "DANGER" | "COLD" | "CRITICAL"
  alertLevel  String?
  acknowledged Boolean  @default(false)
  acknowledgedAt DateTime?

  device      Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp(sort: Desc)])
  @@index([ptiType, timestamp(sort: Desc)])
  @@index([alertModule, timestamp(sort: Desc)])
  @@map("alerts")
}
