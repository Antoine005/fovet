# Ardent Watch — Environment variables template
# Copy to .env and fill in real values. NEVER commit .env.

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (with TimescaleDB in production)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ard_watch"

# ── Auth ─────────────────────────────────────────────────────────────────────
# HS256 JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET="change-me-generate-with-openssl-rand-hex-32"

# Dashboard login password — use a strong random password in production
DASHBOARD_PASSWORD="change-me"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origins allowed to call the API. Comma-separated for multiple origins.
# Production examples:
#   Single : ALLOWED_ORIGIN="https://watch.ardent.io"
#   Multi  : ALLOWED_ORIGIN="https://watch.ardent.io,https://watch-staging.ardent.io"
ALLOWED_ORIGIN="http://localhost:3000"


# ── Redis — rate limiting ─────────────────────────────────────────────────────
# Required for multi-instance / multi-pod deployments.
# Without REDIS_URL the rate limiter falls back to a per-process in-memory Map
# (fine for single-instance dev, unsafe for horizontally-scaled production).
# Uncomment the redis service in docker-compose.yml, then set this value.
# REDIS_URL="redis://localhost:6379"

# ── MQTT ─────────────────────────────────────────────────────────────────────
# Mosquitto broker URL (default: local)
MQTT_BROKER_URL="mqtt://localhost:1883"

# Optional topic prefix (default: ardent/devices)
# MQTT_TOPIC_PREFIX="ardent/devices"

# Broker credentials (required when allow_anonymous false)
MQTT_USERNAME="ardent-watch"
MQTT_PASSWORD="change-me"

# ── Webhook alertes sortantes ────────────────────────────────────────────────
# URL POST appelée à chaque alerte créée (WARN/DANGER/COLD/CRITICAL ou PTI).
# Optionnel — aucune notification si absent.
# Compatible : n8n, Make, Zapier, Slack incoming webhooks, endpoint custom.
# ALERT_WEBHOOK_URL="https://hooks.slack.com/services/xxx/yyy/zzz"

# Niveaux minimum déclenchant le webhook :
# "ALL"      → toutes les alertes (WARN/DANGER/COLD/CRITICAL)
# "DANGER"   → DANGER + CRITICAL uniquement (défaut)
# "CRITICAL" → CRITICAL uniquement
# ALERT_WEBHOOK_MIN_LEVEL="DANGER"
