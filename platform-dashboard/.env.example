# Fovet Vigie — Environment variables template
# Copy to .env and fill in real values. NEVER commit .env.

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (with TimescaleDB in production)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fovet_vigie"

# ── Auth ─────────────────────────────────────────────────────────────────────
# HS256 JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET="change-me-generate-with-openssl-rand-hex-32"

# Dashboard login password — use a strong random password in production
DASHBOARD_PASSWORD="change-me"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origins allowed to call the API. Comma-separated for multiple origins.
# Production examples:
#   Single : ALLOWED_ORIGIN="https://vigie.fovet.eu"
#   Multi  : ALLOWED_ORIGIN="https://vigie.fovet.eu,https://vigie-staging.fovet.eu"
ALLOWED_ORIGIN="http://localhost:3000"

# ── MQTT ─────────────────────────────────────────────────────────────────────
# Mosquitto broker URL (default: local)
MQTT_BROKER_URL="mqtt://localhost:1883"

# Optional topic prefix (default: fovet/devices)
# MQTT_TOPIC_PREFIX="fovet/devices"

# Broker credentials (required when allow_anonymous false)
MQTT_USERNAME="fovet-vigie"
MQTT_PASSWORD="change-me"
